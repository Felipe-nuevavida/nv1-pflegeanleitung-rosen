<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Vida - Installation Guide</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: system-ui, -apple-system, sans-serif; background:#fff; overflow:hidden; }
    .wrap { width:100%; height:100vh; display:flex; flex-direction:column; }

    .intro { display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; gap:2.5rem; background:#fff; }
    .logo-img { width:220px; height:220px; object-fit:contain; }
    .lang-row { display:flex; gap:1.2rem; flex-wrap:wrap; justify-content:center; padding:0 1rem; }
    .lang-btn {
      width:95px; height:95px; border:2px solid #d4a017; background:#fff;
      border-radius:14px; font-size:3.2rem; cursor:pointer;
      transition:all 0.2s; display:flex; align-items:center; justify-content:center;
      box-shadow:0 2px 8px rgba(212,160,23,0.2);
    }
    .lang-btn:hover { border-color:#b8860b; transform:scale(1.08); }
    .lang-btn:active { transform:scale(0.95); }

    .car-screen { display:none; flex-direction:column; width:100%; height:100%; background:#fff; }
    .car-screen.active { display:flex; }

    .prog-bar { width:100%; height:6px; background:#f0f0f0; display:flex; flex-shrink:0; }
    .seg { flex:1; height:100%; background:#e8d5a3; transition:background 0.3s; }
    .seg.done { background:#d4a017; }
    .seg.current { background:#d4a017; }

    .car-content {
      flex:1; display:flex; align-items:flex-start; justify-content:center;
      padding:1rem 1.5rem; position:relative; overflow:hidden;
    }

    .tap-l, .tap-r { position:absolute; top:0; width:20%; height:100%; cursor:pointer; z-index:10; }
    .tap-l { left:0; } .tap-r { right:0; }

    .slide { display:none; text-align:center; width:100%; flex-direction:column; align-items:center; gap:0.85rem; padding-top:0.5rem; animation:fadeSlide 0.3s ease; }
    .slide.active { display:flex; }
    @keyframes fadeSlide { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

    .step-num {
      font-size:8rem; font-weight:900; line-height:0.9;
      background:linear-gradient(135deg,#c8a415 0%,#f5d87a 45%,#a07810 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      font-family:Georgia,serif;
    }
    .divider { width:70px; height:3px; background:linear-gradient(90deg,#c8a415,#f0c93a,#c8a415); border-radius:2px; }
    .slide h2 { font-size:1.9rem; font-weight:800; color:#1a1a1a; line-height:1.2; }
    .slide p { font-size:1.35rem; line-height:1.6; color:#333; max-width:400px; }
    .warn { font-size:1.25rem; color:#b91c1c; font-weight:800; background:#fff1f1; border:2px solid #f5c6c6; padding:0.65rem 1.2rem; border-radius:10px; display:inline-block; }

    .logo-small { position:absolute; top:10px; right:14px; width:56px; height:56px; object-fit:contain; opacity:0.75; z-index:5; pointer-events:none; }

    .final-title { font-size:2.4rem; font-weight:900; color:#1a1a1a; line-height:1.2; }
    .support-btn {
      padding:1rem 2.5rem; font-size:1.2rem;
      background:linear-gradient(135deg,#c8a415,#f0c93a,#a07810);
      color:#fff; border:none; border-radius:12px; cursor:pointer;
      font-weight:800; letter-spacing:0.03em;
      box-shadow:0 2px 12px rgba(180,130,0,0.4);
      text-decoration:none; display:inline-block; transition:all 0.2s;
      margin-top:0.3rem;
    }
    .support-btn:hover { transform:scale(1.04); }
    .support-btn:active { transform:scale(0.97); }
  </style>
</head>
<body>
<div class="wrap">
  <div class="intro" id="introScreen">
    <img src="Logo_gold.png" class="logo-img" alt="Nueva Vida" onerror="this.style.display='none'">
    <div class="lang-row">
      <button class="lang-btn" onclick="go('de')">🇩🇪</button>
      <button class="lang-btn" onclick="go('en')">🇬🇧</button>
      <button class="lang-btn" onclick="go('fr')">🇫🇷</button>
      <button class="lang-btn" onclick="go('es')">🇪🇸</button>
      <button class="lang-btn" onclick="go('it')">🇮🇹</button>
    </div>
  </div>

  <div class="car-screen" id="carScreen">
    <div class="prog-bar">
      <div class="seg current" id="s0"></div>
      <div class="seg" id="s1"></div>
      <div class="seg" id="s2"></div>
      <div class="seg" id="s3"></div>
    </div>
    <div class="car-content">
      <div class="tap-l" onclick="prev()"></div>
      <img src="Logo_gold.png" class="logo-small" alt="" onerror="this.style.display='none'">
      <div id="slides" style="width:100%"></div>
      <div class="tap-r" onclick="next()"></div>
    </div>
  </div>
</div>

<script>
const C={
  de:[
    {n:'1',t:'HAUBE REINIGEN 🧼',b:'Fläche staub- und fettfrei machen.',w:'❗ KEIN WACHS! KEINE POLITUR!'},
    {n:'2',t:'VAKUUM DRÜCKEN ✋',b:'Saugnäpfe leicht anfeuchten. Direkt auf den Saugnapf drücken – NIEMALS auf die Blüte!',w:''},
    {n:'3',t:'SICHER ENTFERNEN 🔓',b:'Zum Abnehmen NUR an der kleinen Lasche ziehen.',w:'❗ NIEMALS an der Blume reißen!'},
    {n:'4',t:'GUTE FAHRT! 🚗💨',b:'',w:'❗ MAX. 80 KM/H',f:1}
  ],
  en:[
    {n:'1',t:'CLEAN THE HOOD 🧼',b:'Surface must be completely dust and grease-free.',w:'❗ NO WAX! NO POLISH!'},
    {n:'2',t:'PRESS & SECURE ✋',b:'Moisten suction cups slightly. Press the suction cup directly – NEVER press the flower!',w:''},
    {n:'3',t:'SAFE REMOVAL 🔓',b:'To remove, pull ONLY the small tab on the suction cup.',w:'❗ NEVER rip the flower off!'},
    {n:'4',t:'HAVE A GREAT DRIVE! 🚗💨',b:'',w:'❗ MAX. 80 KM/H',f:1}
  ],
  fr:[
    {n:'1',t:'NETTOYER LE CAPOT 🧼',b:'La surface doit être sans poussière ni graisse.',w:'❗ PAS DE CIRE ! PAS DE POLISH !'},
    {n:'2',t:'PRESSER LA VENTOUSE ✋',b:'Humidifiez légèrement les ventouses. Appuyez directement sur la ventouse, JAMAIS sur la fleur !',w:''},
    {n:'3',t:'RETRAIT SÉCURISÉ 🔓',b:'Pour retirer, tirez UNIQUEMENT sur la petite languette.',w:'❗ NE JAMAIS arracher la fleur !'},
    {n:'4',t:'BONNE ROUTE ! 🚗💨',b:'',w:'❗ MAX. 80 KM/H',f:1}
  ],
  es:[
    {n:'1',t:'LIMPIAR EL CAPÓ 🧼',b:'La superficie debe estar sin polvo ni grasa.',w:'❗ ¡CERO CERA! ¡CERO PULIMIENTO!'},
    {n:'2',t:'PRESIONAR LA VENTOSA ✋',b:'Humedezca ligeramente las ventosas. Presione directamente la ventosa, ¡NUNCA la flor!',w:''},
    {n:'3',t:'RETIRADA SEGURA 🔓',b:'Para quitar, tire SOLO de la pequeña lengüeta.',w:'❗ ¡NUNCA arranque la flor!'},
    {n:'4',t:'¡BUEN VIAJE! 🚗💨',b:'',w:'❗ MÁX. 80 KM/H',f:1}
  ],
  it:[
    {n:'1',t:'PULIRE IL COFANO 🧼',b:'La superficie deve essere senza polvere e grasso.',w:'❗ NIENTE CERA! NIENTE LUCIDO!'},
    {n:'2',t:'PREMERE LA VENTOSA ✋',b:'Inumidire leggermente le ventose. Premere direttamente la ventosa, MAI il fiore!',w:''},
    {n:'3',t:'RIMOZIONE SICURA 🔓',b:'Per rimuovere, tirare SOLO la piccola linguetta.',w:'❗ MAI strappare il fiore!'},
    {n:'4',t:'BUON VIAGGIO! 🚗💨',b:'',w:'❗ MAX. 80 KM/H',f:1}
  ]
};
const ST={de:'Support kontaktieren',en:'Contact Support',fr:'Contacter le Support',es:'Contactar Soporte',it:'Contatta il Supporto'};
let lang='de',cur=0,timer=null;

function go(l){
  lang=l; cur=0;
  document.getElementById('introScreen').style.display='none';
  document.getElementById('carScreen').classList.add('active');
  render(); show(0); adv();
}
function render(){
  const c=document.getElementById('slides'); c.innerHTML='';
  C[lang].forEach((s,i)=>{
    const d=document.createElement('div');
    d.className='slide'+(i===0?' active':'');
    if(s.f){
      d.innerHTML=`<div class="step-num">${s.n}</div><div class="divider"></div><div class="final-title">${s.t}</div>${s.w?`<div class="warn">${s.w}</div>`:''}<a href="mailto:info@nuevavida-ftv.de" class="support-btn">${ST[lang]}</a>`;
    } else {
      d.innerHTML=`<div class="step-num">${s.n}</div><div class="divider"></div><h2>${s.t}</h2>${s.b?`<p>${s.b}</p>`:''}${s.w?`<div class="warn">${s.w}</div>`:''}`;
    }
    c.appendChild(d);
  });
}
function show(i){
  document.querySelectorAll('.slide').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.seg').forEach((s,j)=>{
    s.classList.remove('current','done');
    if(j<i) s.classList.add('done'); else if(j===i) s.classList.add('current');
  });
  document.querySelectorAll('.slide')[i]?.classList.add('active');
}
function next(){if(cur<C[lang].length-1){cur++;show(cur);cur<C[lang].length-1?resetAdv():clearTimeout(timer);}}
function prev(){if(cur>0){cur--;show(cur);resetAdv();}}
function adv(){if(cur<C[lang].length-1)timer=setTimeout(()=>{next();adv();},5000);}
function resetAdv(){clearTimeout(timer);adv();}
</script>
</body>
</html>
